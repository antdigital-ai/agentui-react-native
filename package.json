{
  "name": "@antdigital/agentui-react-native",
  "version": "0.1.2",
  "packageManager": "npm@10.9.2",
  "description": "Agent UI components for React Native — Markdown renderer with streaming",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antdigital-ai/agentui-react-native.git"
  },
  "bugs": {
    "url": "https://github.com/antdigital-ai/agentui-react-native/issues"
  },
  "homepage": "https://github.com/antdigital-ai/agentui-react-native#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "main": "lib/index.js",
  "module": "lib/index.mjs",
  "types": "lib/index.d.ts",
  "react-native": "lib/index.js",
  "source": "src/index.ts",
  "browser": "src/index.ts",
  "exports": {
    ".": {
      "react-native": "./lib/index.js",
      "browser": "./src/index.ts",
      "import": "./lib/index.mjs",
      "require": "./lib/index.js",
      "default": "./lib/index.js"
    },
    "./theme/markdownWebReset.css": "./src/theme/markdownWebReset.css"
  },
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepare": "npm run build",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run test && npm run build",
    "prepublishOnly": "npm run build",
    "release": "np --no-publish",
    "release:preview": "np --no-publish --dry-run",
    "example": "npm run start --prefix example",
    "example:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-example.ps1",
    "example:android": "npm run android --prefix example",
    "example:ios": "npm run ios --prefix example",
    "example:web": "npm run web --prefix example"
  },
  "np": {
    "branch": "main",
    "testScript": "verify",
    "publish": false,
    "message": "v%s"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@react-native/babel-preset": "^0.85.3",
    "@react-native/jest-preset": "^0.85.3",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.0",
    "esbuild": "^0.25.0",
    "glob": "^11.0.0",
    "hast-util-to-jsx-runtime": "^2.3.4",
    "jest": "^29.7.0",
    "np": "^11.0.2",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-test-renderer": "19.2.3",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "typescript": "^5.7.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  },
  "license": "MIT"
}
